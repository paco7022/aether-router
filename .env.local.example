# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for CORS origin check)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Comma-separated list of allowed CORS origins (optional, overrides SITE_URL)
# ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Admin emails (comma-separated, defaults to hardcoded list if not set)
# ADMIN_EMAILS=admin@example.com

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Providers (all API keys are REQUIRED — no defaults)
AIRFORCE_API_KEY=your-airforce-api-key

GEMINI_CLI_URL=https://api.aether-ai.dev/v1
GEMINI_CLI_API_KEY=your-gemini-cli-api-key

TROLLLLM_BASE_URL=https://chat.trollllm.xyz/v1
TROLLLLM_API_KEY=your-trolllm-api-key

ANTIGRAVITY_BASE_URL=https://api.aether-ai.dev/v1
ANTIGRAVITY_API_KEY=your-antigravity-api-key

WEBPROXY_BASE_URL=https://api1.aether-ai.dev/v1
WEBPROXY_API_KEY=your-webproxy-api-key

NANO_API_KEY=your-nano-gpt-api-key
NANO_BASE_URL=https://nano-gpt.com/api/v1

# Hapuppy (h/)
HAPUPPY_BASE_URL=https://api.hapuppy.com/v1
HAPUPPY_API_KEY=your-hapuppy-api-key

# Gameron (gm/) — primary + secondary for auto key rotation on 401/403
GAMERON_BASE_URL=https://api.gameron.me/v1
GAMERON_PRIMARY_KEY=your-gameron-primary-key
GAMERON_SECONDARY_KEY=your-gameron-secondary-key
